<Window x:Class="QuizWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quiz App - Vizualizare" Height="650" Width="800"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Stil pentru titluri de secțiune -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#3A3A5C"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Stil pentru etichete câmpuri -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <!-- Stil pentru valorile câmpurilor -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Stil pentru card -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stil pentru butoane -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4A6CF7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3555E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Badge pentru dificultate -->
        <Style x:Key="BadgeEasy" TargetType="Border">
            <Setter Property="Background" Value="#D4EDDA"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
        <Style x:Key="BadgeMedium" TargetType="Border">
            <Setter Property="Background" Value="#FFF3CD"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
        <Style x:Key="BadgeHard" TargetType="Border">
            <Setter Property="Background" Value="#F8D7DA"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#3A3A5C">
            <Grid Margin="30,0">
                <TextBlock Text="🎯 Quiz App"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Content="➕ Adaugă Întrebare"
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Height="34" Padding="14,0"
        FontSize="13" FontWeight="Bold"
        Foreground="White"
        Background="#4A6CF7"
        BorderThickness="0"
        Cursor="Hand"
        Click="OnAdaugaIntrebare">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Conținut principal -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20">
            <StackPanel>

                <!-- Secțiunea Selectare -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Selectare Date" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ID Întrebare" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtIdIntrebare"
                                         Height="36" FontSize="13"
                                         Padding="10,0"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#DDDDDD"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Domeniu" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TxtDomeniu"
                                         Height="36" FontSize="13"
                                         Padding="10,0"
                                         VerticalContentAlignment="Center"
                                         BorderBrush="#DDDDDD"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                <Button Content="Caută"
                                        Style="{StaticResource ActionButton}"
                                        Width="100"
                                        Click="OnCautaIntrebare"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Card Întrebare -->
                <Border x:Name="CardIntrebare" Style="{StaticResource CardBorder}" Visibility="Collapsed">
                    <StackPanel>
                        <!-- Header card -->
                        <Grid Margin="0,0,0,16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📝 " FontSize="18"/>
                                <TextBlock Text="Detalii Întrebare"
                                           Style="{StaticResource SectionTitle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border x:Name="BadgeDificultate" CornerRadius="20" Padding="10,4"
                                        Background="#D4EDDA">
                                    <TextBlock x:Name="TbDificultate"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="#155724"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="#F0F0F0" Margin="0,0,0,16"/>

                        <!-- Rând 1: ID și Domeniu -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="ID Întrebare" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TbIdIntrebare" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Domeniu" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TbDomeniu" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Text întrebare -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Text Întrebare" Style="{StaticResource FieldLabel}"/>
                            <Border Background="#F8F9FF" CornerRadius="6" Padding="12,10">
                                <TextBlock x:Name="TbTextIntrebare"
                                           FontSize="14" Foreground="#1A1A2E"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <!-- Variante răspuns -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="Variante de Răspuns" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Border x:Name="BorderA" Grid.Row="0" Grid.Column="0"
                                        BorderBrush="#DDDDDD" BorderThickness="1"
                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="A) " FontWeight="Bold" Foreground="#4A6CF7"/>
                                        <TextBlock x:Name="TbVariantaA" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="BorderB" Grid.Row="0" Grid.Column="2"
                                        BorderBrush="#DDDDDD" BorderThickness="1"
                                        CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="B) " FontWeight="Bold" Foreground="#4A6CF7"/>
                                        <TextBlock x:Name="TbVariantaB" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="BorderC" Grid.Row="1" Grid.Column="0"
                                        BorderBrush="#DDDDDD" BorderThickness="1"
                                        CornerRadius="6" Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="C) " FontWeight="Bold" Foreground="#4A6CF7"/>
                                        <TextBlock x:Name="TbVariantaC" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="BorderD" Grid.Row="1" Grid.Column="2"
                                        BorderBrush="#DDDDDD" BorderThickness="1"
                                        CornerRadius="6" Padding="12,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="D) " FontWeight="Bold" Foreground="#4A6CF7"/>
                                        <TextBlock x:Name="TbVariantaD" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Rând 3: Răspuns corect și Tip cunoștințe -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Răspuns Corect" Style="{StaticResource FieldLabel}"/>
                                <Border Background="#D4EDDA" CornerRadius="6" Padding="12,8" HorizontalAlignment="Left">
                                    <TextBlock x:Name="TbRaspunsCorect"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="#155724"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Tip Cunoștințe" Style="{StaticResource FieldLabel}"/>
                                <TextBlock x:Name="TbTipCunostinte" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Mesaj eroare / gol -->
                <Border x:Name="CardMesaj" Style="{StaticResource CardBorder}" Visibility="Collapsed">
                    <TextBlock x:Name="TbMesaj"
                               FontSize="14" Foreground="#888888"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
