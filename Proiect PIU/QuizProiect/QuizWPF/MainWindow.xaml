<Window x:Class="QuizWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quiz App" Height="720" Width="1000" MinHeight="560" MinWidth="720"
        Background="#F0F2F8"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- ── Stiluri globale ── -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#3A3A5C"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#666688"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buton primar albastru -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4A6CF7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3555E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#AAAACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buton pericol rosu -->
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#DC3545"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B02030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Buton succes verde -->
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#28A745"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E7E34"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Buton secundar gri -->
        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#6C757D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#545B62"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox standard -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCCCDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#4A6CF7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox standard -->
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCCCDD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Label câmp formular -->
        <Style x:Key="FormLabel" TargetType="Label">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#3A3A5C"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <!-- Mesaj eroare -->
        <Style x:Key="ErrorMsg" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#DC3545"/>
            <Setter Property="Margin" Value="2,2,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <!-- Item ListBox întrebări -->
        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EEEEF5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF0FF"/>
                    <Setter Property="Foreground" Value="#3A3A5C"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F7FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Menu -->
            <RowDefinition Height="64"/>    <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ══ MENIU ══ -->
        <Menu Grid.Row="0" Background="#2D2D50" Foreground="White" FontSize="13">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#2D2D50"/>
                    <Setter Property="Padding" Value="12,6"/>
                </Style>
            </Menu.Resources>
            <MenuItem Header="📋 Întrebări">
                <MenuItem Header="➕ Adaugă Întrebare" Click="OnAdaugaIntrebare"/>
                <MenuItem Header="✏️ Editează Întrebare Selectată" Click="OnEditeazaIntrebare"/>
                <Separator/>
                <MenuItem Header="🔄 Reîncarcă Lista" Click="OnReincarcaLista"/>
            </MenuItem>
            <MenuItem Header="🔍 Căutare">
                <MenuItem Header="Caută după ID" Click="OnCautaDupaId"/>
                <MenuItem Header="Caută după Domeniu" Click="OnCautaDupaDomeniu"/>
                <MenuItem Header="Caută după Dificultate" Click="OnCautaDupaDificultate"/>
                <Separator/>
                <MenuItem Header="Afișează toate" Click="OnAfiseazaTot"/>
            </MenuItem>
            <MenuItem Header="ℹ️ Ajutor">
                <MenuItem Header="Despre aplicație" Click="OnDespre"/>
            </MenuItem>
        </Menu>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="1" Background="#3A3A5C">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="🎯 Quiz App"
                           Foreground="White" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="TbSubtitlu"
                           Text="Gestionare întrebări quiz"
                           Foreground="#AAAACC" FontSize="13"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="➕ Adaugă" Style="{StaticResource BtnPrimary}"
                            Click="OnAdaugaIntrebare" Margin="0,0,8,0"/>
                    <Button Content="✏️ Editează" Style="{StaticResource BtnSuccess}"
                            Click="OnEditeazaIntrebare"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ CONȚINUT PRINCIPAL (2 coloane responsive) ══ -->
        <Grid Grid.Row="2" Margin="16,12,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ─── COLOANA STÂNGA: Căutare + ListBox ─── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Card Căutare -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="🔍 Filtrare și Căutare" Style="{StaticResource SectionTitle}"/>

                        <!-- Câmp text căutare -->
                        <Label Content="Caută (text liber):" Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="TxtCautare" Style="{StaticResource InputBox}"
                                 Margin="0,0,0,8"
                                 TextChanged="OnCautareTextChanged"
                                 ToolTip="Scrie ID, domeniu sau text din întrebare"/>

                        <!-- Filtru Dificultate cu RadioButton -->
                        <Label Content="Filtrare după dificultate:" Style="{StaticResource FormLabel}"/>
                        <WrapPanel Margin="0,0,0,8">
                            <RadioButton x:Name="RbToate" Content="Toate" IsChecked="True"
                                         Margin="0,0,12,4" FontSize="12"
                                         Checked="OnFiltruDificultateChanged"/>
                            <RadioButton x:Name="RbUsor" Content="Ușor"
                                         Margin="0,0,12,4" FontSize="12"
                                         Checked="OnFiltruDificultateChanged"/>
                            <RadioButton x:Name="RbMediu" Content="Mediu"
                                         Margin="0,0,12,4" FontSize="12"
                                         Checked="OnFiltruDificultateChanged"/>
                            <RadioButton x:Name="RbGreu" Content="Greu"
                                         Margin="0,0,0,4" FontSize="12"
                                         Checked="OnFiltruDificultateChanged"/>
                        </WrapPanel>

                        <!-- Filtru Tip Cunoștințe cu CheckBox -->
                        <Label Content="Filtrare după tip cunoștințe:" Style="{StaticResource FormLabel}"/>
                        <WrapPanel Margin="0,0,0,4">
                            <CheckBox x:Name="ChkFiltruTeorie" Content="Teorie"
                                      Margin="0,0,10,4" FontSize="12"
                                      Checked="OnFiltruTipChanged" Unchecked="OnFiltruTipChanged"/>
                            <CheckBox x:Name="ChkFiltruPractica" Content="Practică"
                                      Margin="0,0,10,4" FontSize="12"
                                      Checked="OnFiltruTipChanged" Unchecked="OnFiltruTipChanged"/>
                            <CheckBox x:Name="ChkFiltruSintaxa" Content="Sintaxă"
                                      Margin="0,0,10,4" FontSize="12"
                                      Checked="OnFiltruTipChanged" Unchecked="OnFiltruTipChanged"/>
                            <CheckBox x:Name="ChkFiltruAlgoritmi" Content="Algoritmi"
                                      Margin="0,0,0,4" FontSize="12"
                                      Checked="OnFiltruTipChanged" Unchecked="OnFiltruTipChanged"/>
                        </WrapPanel>

                        <Button Content="🔄 Resetează Filtre" Style="{StaticResource BtnSecondary}"
                                Height="30" FontSize="11" Margin="0,4,0,0"
                                Click="OnResetFiltre"/>
                    </StackPanel>
                </Border>

                <!-- ListBox Întrebări -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#F5F7FF"
                                CornerRadius="10,10,0,0" Padding="12,8">
                            <Grid>
                                <TextBlock Text="📋 Lista Întrebărilor" FontWeight="Bold"
                                           FontSize="12" Foreground="#3A3A5C" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TbNrIntrebari" Text="0 întrebări"
                                           FontSize="11" Foreground="#888888"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ListBox Grid.Row="1" x:Name="LstIntrebari"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                                 SelectionChanged="OnIntrebareSelectata">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding DisplayId}"
                                                       FontWeight="Bold" FontSize="11"
                                                       Foreground="#4A6CF7"/>
                                            <Border HorizontalAlignment="Right"
                                                    CornerRadius="10" Padding="6,1"
                                                    Background="{Binding DificultateColor}">
                                                <TextBlock Text="{Binding DificultateText}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{Binding DificultateTextColor}"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding DomeniuText}"
                                                   FontSize="11" Foreground="#555577"
                                                   Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding TextScurt}"
                                                   FontSize="12" Foreground="#1A1A2E"
                                                   TextWrapping="Wrap" Margin="0,2,0,0"
                                                   MaxHeight="36"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2" Background="#F5F7FF"
                                CornerRadius="0,0,10,10" Padding="8,6">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="✏️ Editează" Style="{StaticResource BtnPrimary}"
                                        Height="28" FontSize="11" Margin="0,0,6,0"
                                        Click="OnEditeazaIntrebare"/>
                                <Button Content="🗑️ Șterge" Style="{StaticResource BtnDanger}"
                                        Height="28" FontSize="11"
                                        Click="OnStergeIntrebare"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── COLOANA DREAPTA: Detalii / Edit ─── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Panou taburi Vizualizare / Editare -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,0">
                    <TabControl x:Name="TabPrincipal" BorderThickness="0" Background="Transparent">
                        <TabItem Header="👁️ Vizualizare" x:Name="TabVizualizare">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                                <!-- Card detalii (vizibil când e selectată o întrebare) -->
                                <StackPanel>
                                    <Border x:Name="PanelGol" Padding="20" Visibility="Visible">
                                        <TextBlock Text="← Selectați o întrebare din lista din stânga pentru a vedea detaliile."
                                                   Foreground="#AAAACC" FontSize="13"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <StackPanel x:Name="PanelDetalii" Visibility="Collapsed">
                                        <!-- Header detalii -->
                                        <Grid Margin="0,0,0,12">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📝 " FontSize="18"/>
                                                <TextBlock Text="Detalii Întrebare"
                                                           Style="{StaticResource SectionTitle}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Border x:Name="BadgeDificultate" HorizontalAlignment="Right"
                                                    CornerRadius="20" Padding="12,4" Background="#D4EDDA">
                                                <TextBlock x:Name="TbDificultate"
                                                           FontSize="12" FontWeight="Bold" Foreground="#155724"/>
                                            </Border>
                                        </Grid>

                                        <Rectangle Height="1" Fill="#EEEEEE" Margin="0,0,0,12"/>

                                        <!-- ID și Domeniu -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="80"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="ID" Style="{StaticResource FieldLabel}"/>
                                                <TextBlock x:Name="TbIdIntrebare" Style="{StaticResource FieldValue}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Domeniu" Style="{StaticResource FieldLabel}"/>
                                                <TextBlock x:Name="TbDomeniu" Style="{StaticResource FieldValue}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Text întrebare -->
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Text Întrebare" Style="{StaticResource FieldLabel}"/>
                                            <Border Background="#F8F9FF" CornerRadius="6" Padding="12,10">
                                                <TextBlock x:Name="TbTextIntrebare"
                                                           FontSize="14" Foreground="#1A1A2E" TextWrapping="Wrap"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Variante -->
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Variante de Răspuns" Style="{StaticResource FieldLabel}"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/>
                                                    <RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <Border x:Name="BorderA" Grid.Row="0" Grid.Column="0"
                                                        BorderBrush="#DDDDDD" BorderThickness="1"
                                                        CornerRadius="6" Padding="10,7" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="A) " FontWeight="Bold" Foreground="#4A6CF7"/>
                                                        <TextBlock x:Name="TbVariantaA" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="BorderB" Grid.Row="0" Grid.Column="2"
                                                        BorderBrush="#DDDDDD" BorderThickness="1"
                                                        CornerRadius="6" Padding="10,7" Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="B) " FontWeight="Bold" Foreground="#4A6CF7"/>
                                                        <TextBlock x:Name="TbVariantaB" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="BorderC" Grid.Row="1" Grid.Column="0"
                                                        BorderBrush="#DDDDDD" BorderThickness="1"
                                                        CornerRadius="6" Padding="10,7">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="C) " FontWeight="Bold" Foreground="#4A6CF7"/>
                                                        <TextBlock x:Name="TbVariantaC" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border x:Name="BorderD" Grid.Row="1" Grid.Column="2"
                                                        BorderBrush="#DDDDDD" BorderThickness="1"
                                                        CornerRadius="6" Padding="10,7">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="D) " FontWeight="Bold" Foreground="#4A6CF7"/>
                                                        <TextBlock x:Name="TbVariantaD" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Răspuns corect și Tip cunoștințe -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Răspuns Corect" Style="{StaticResource FieldLabel}"/>
                                                <Border Background="#D4EDDA" CornerRadius="6" Padding="12,7" HorizontalAlignment="Left">
                                                    <TextBlock x:Name="TbRaspunsCorect"
                                                               FontSize="16" FontWeight="Bold" Foreground="#155724"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Tip Cunoștințe" Style="{StaticResource FieldLabel}"/>
                                                <TextBlock x:Name="TbTipCunostinte" Style="{StaticResource FieldValue}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- TAB EDITARE -->
                        <TabItem Header="✏️ Editare" x:Name="TabEditare">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16">
                                    <Border x:Name="PanelEditGol" Padding="20" Visibility="Visible">
                                        <TextBlock Text="← Selectați o întrebare din lista din stânga pentru a o edita."
                                                   Foreground="#AAAACC" FontSize="13"
                                                   TextWrapping="Wrap" TextAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <StackPanel x:Name="PanelEdit" Visibility="Collapsed">
                                        <TextBlock Text="✏️ Editare Întrebare" Style="{StaticResource SectionTitle}"/>
                                        <Rectangle Height="1" Fill="#EEEEEE" Margin="0,0,0,12"/>

                                        <!-- Domeniu -->
                                        <StackPanel Margin="0,0,0,10">
                                            <Label x:Name="LblEditDomeniu" Content="Domeniu *" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="TxtEditDomeniu" Style="{StaticResource InputBox}"/>
                                            <TextBlock x:Name="ErrEditDomeniu" Style="{StaticResource ErrorMsg}"
                                                       Text="Domeniul trebuie să aibă minim 2 caractere."/>
                                        </StackPanel>

                                        <!-- Text întrebare -->
                                        <StackPanel Margin="0,0,0,10">
                                            <Label x:Name="LblEditText" Content="Text Întrebare *" Style="{StaticResource FormLabel}"/>
                                            <TextBox x:Name="TxtEditText" Height="70" FontSize="13"
                                                     Padding="8" TextWrapping="Wrap" AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     BorderBrush="#CCCCDD"/>
                                            <TextBlock x:Name="ErrEditText" Style="{StaticResource ErrorMsg}"
                                                       Text="Textul trebuie să aibă minim 10 caractere."/>
                                        </StackPanel>

                                        <!-- Variante A/B -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <Label x:Name="LblEditVarA" Content="Varianta A *" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="TxtEditVarA" Style="{StaticResource InputBox}"/>
                                                <TextBlock x:Name="ErrEditVarA" Style="{StaticResource ErrorMsg}"
                                                           Text="Varianta A este obligatorie."/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <Label x:Name="LblEditVarB" Content="Varianta B *" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="TxtEditVarB" Style="{StaticResource InputBox}"/>
                                                <TextBlock x:Name="ErrEditVarB" Style="{StaticResource ErrorMsg}"
                                                           Text="Varianta B este obligatorie."/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Variante C/D -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <Label x:Name="LblEditVarC" Content="Varianta C *" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="TxtEditVarC" Style="{StaticResource InputBox}"/>
                                                <TextBlock x:Name="ErrEditVarC" Style="{StaticResource ErrorMsg}"
                                                           Text="Varianta C este obligatorie."/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <Label x:Name="LblEditVarD" Content="Varianta D *" Style="{StaticResource FormLabel}"/>
                                                <TextBox x:Name="TxtEditVarD" Style="{StaticResource InputBox}"/>
                                                <TextBlock x:Name="ErrEditVarD" Style="{StaticResource ErrorMsg}"
                                                           Text="Varianta D este obligatorie."/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Răspuns corect și Dificultate -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <Label x:Name="LblEditRaspuns" Content="Răspuns Corect *" Style="{StaticResource FormLabel}"/>
                                                <ComboBox x:Name="CmbEditRaspuns" Style="{StaticResource InputCombo}">
                                                    <ComboBoxItem Content="A (index 0)"/>
                                                    <ComboBoxItem Content="B (index 1)"/>
                                                    <ComboBoxItem Content="C (index 2)"/>
                                                    <ComboBoxItem Content="D (index 3)"/>
                                                </ComboBox>
                                                <TextBlock x:Name="ErrEditRaspuns" Style="{StaticResource ErrorMsg}"
                                                           Text="Selectați răspunsul corect."/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <Label Content="Dificultate" Style="{StaticResource FormLabel}"/>
                                                <ComboBox x:Name="CmbEditDificultate" Style="{StaticResource InputCombo}" SelectedIndex="0">
                                                    <ComboBoxItem Content="Ușor"/>
                                                    <ComboBoxItem Content="Mediu"/>
                                                    <ComboBoxItem Content="Greu"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Tip cunoștințe -->
                                        <StackPanel Margin="0,0,0,12">
                                            <Label Content="Tip Cunoștințe" Style="{StaticResource FormLabel}"/>
                                            <WrapPanel>
                                                <CheckBox x:Name="ChkEditTeorie" Content="Teorie"
                                                          Margin="0,0,14,4" FontSize="12"/>
                                                <CheckBox x:Name="ChkEditPractica" Content="Practică"
                                                          Margin="0,0,14,4" FontSize="12"/>
                                                <CheckBox x:Name="ChkEditSintaxa" Content="Sintaxă"
                                                          Margin="0,0,14,4" FontSize="12"/>
                                                <CheckBox x:Name="ChkEditAlgoritmi" Content="Algoritmi"
                                                          FontSize="12"/>
                                            </WrapPanel>
                                        </StackPanel>

                                        <!-- Mesaje feedback -->
                                        <Border x:Name="PanelEditSucces" Background="#D4EDDA"
                                                CornerRadius="6" Padding="12,8" Margin="0,4,0,8"
                                                Visibility="Collapsed">
                                            <TextBlock Text="✔  Întrebarea a fost actualizată cu succes!"
                                                       Foreground="#155724" FontWeight="Bold" FontSize="12"/>
                                        </Border>
                                        <Border x:Name="PanelEditEroare" Background="#F8D7DA"
                                                CornerRadius="6" Padding="12,8" Margin="0,4,0,8"
                                                Visibility="Collapsed">
                                            <TextBlock Text="✖  A apărut o eroare la salvare. Verificați datele."
                                                       Foreground="#721C24" FontWeight="Bold" FontSize="12"/>
                                        </Border>

                                        <!-- Butoane -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="✖ Anulează"
                                                    Style="{StaticResource BtnSecondary}"
                                                    Click="OnAnuleazaEdit"/>
                                            <Button Grid.Column="2" Content="💾 Salvează Modificările"
                                                    Style="{StaticResource BtnSuccess}"
                                                    Click="OnSalveazaEdit"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
