<Window x:Class="QuizWPF.AdaugaIntrebareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adaugă Întrebare Nouă"
        Height="740" Width="640" MinHeight="600" MinWidth="520"
        Background="#F0F2F8"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Stiluri comune — identice cu MainWindow pentru consistență -->
        <Style x:Key="FormLabel" TargetType="Label">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#3A3A5C"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCCCDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#4A6CF7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCCCDD"/>
        </Style>

        <Style x:Key="ErrorMsg" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#DC3545"/>
            <Setter Property="Margin" Value="2,2,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4A6CF7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3555E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#6C757D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#545B62"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>  <!-- Header -->
            <RowDefinition Height="*"/>   <!-- Formular -->
            <RowDefinition Height="Auto"/><!-- Footer butoane -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Background="#3A3A5C">
            <TextBlock Text="➕  Adaugă Întrebare Nouă"
                       Foreground="White" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="24,0"/>
        </Border>

        <!-- ══ FORMULAR ══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,18,24,12">

                <!-- Domeniu + Data creării (DatePicker) pe același rând -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <Label x:Name="LblDomeniu" Content="_Domeniu *" Style="{StaticResource FormLabel}"
                               Target="{Binding ElementName=TxtDomeniu}"/>
                        <TextBox x:Name="TxtDomeniu" Style="{StaticResource InputBox}"
                                 ToolTip="Ex: C/C++, Java, Python, General"/>
                        <TextBlock x:Name="ErrDomeniu" Style="{StaticResource ErrorMsg}"
                                   Text="Domeniu invalid (2–50 caractere)."/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Label Content="Data Creării" Style="{StaticResource FormLabel}"/>
                        <DatePicker x:Name="DpDataCreare"
                                    Height="34" FontSize="13"
                                    BorderBrush="#CCCCDD"
                                    SelectedDate="{x:Static sys:DateTime.Now}"
                                    xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                    </StackPanel>
                </Grid>

                <!-- Text întrebare -->
                <StackPanel Margin="0,0,0,12">
                    <Label x:Name="LblText" Content="_Text Întrebare *" Style="{StaticResource FormLabel}"
                           Target="{Binding ElementName=TxtTextIntrebare}"/>
                    <TextBox x:Name="TxtTextIntrebare" Height="72" FontSize="13"
                             Padding="8" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" BorderBrush="#CCCCDD"/>
                    <TextBlock x:Name="ErrText" Style="{StaticResource ErrorMsg}"
                               Text="Textul trebuie să aibă între 10 și 300 caractere."/>
                </StackPanel>

                <!-- Variante A și B -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label x:Name="LblVarA" Content="Varianta _A *" Style="{StaticResource FormLabel}"
                               Target="{Binding ElementName=TxtVarA}"/>
                        <TextBox x:Name="TxtVarA" Style="{StaticResource InputBox}"/>
                        <TextBlock x:Name="ErrVarA" Style="{StaticResource ErrorMsg}" Text="Varianta A este obligatorie."/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label x:Name="LblVarB" Content="Varianta _B *" Style="{StaticResource FormLabel}"
                               Target="{Binding ElementName=TxtVarB}"/>
                        <TextBox x:Name="TxtVarB" Style="{StaticResource InputBox}"/>
                        <TextBlock x:Name="ErrVarB" Style="{StaticResource ErrorMsg}" Text="Varianta B este obligatorie."/>
                    </StackPanel>
                </Grid>

                <!-- Variante C și D -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label x:Name="LblVarC" Content="Varianta _C *" Style="{StaticResource FormLabel}"
                               Target="{Binding ElementName=TxtVarC}"/>
                        <TextBox x:Name="TxtVarC" Style="{StaticResource InputBox}"/>
                        <TextBlock x:Name="ErrVarC" Style="{StaticResource ErrorMsg}" Text="Varianta C este obligatorie."/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label x:Name="LblVarD" Content="Varianta _D *" Style="{StaticResource FormLabel}"
                               Target="{Binding ElementName=TxtVarD}"/>
                        <TextBox x:Name="TxtVarD" Style="{StaticResource InputBox}"/>
                        <TextBlock x:Name="ErrVarD" Style="{StaticResource ErrorMsg}" Text="Varianta D este obligatorie."/>
                    </StackPanel>
                </Grid>

                <!-- Răspuns corect (RadioButton) și ComboBox Dificultate -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Răspuns corect prin RadioButton -->
                    <StackPanel Grid.Column="0">
                        <Label x:Name="LblRaspuns" Content="_Răspuns Corect *" Style="{StaticResource FormLabel}"/>
                        <Border BorderBrush="#CCCCDD" BorderThickness="1" CornerRadius="4" Padding="8,6">
                            <WrapPanel>
                                <RadioButton x:Name="RbA" Content="A" GroupName="Raspuns"
                                             Margin="0,0,14,0" FontSize="13" FontWeight="Bold"/>
                                <RadioButton x:Name="RbB" Content="B" GroupName="Raspuns"
                                             Margin="0,0,14,0" FontSize="13" FontWeight="Bold"/>
                                <RadioButton x:Name="RbC" Content="C" GroupName="Raspuns"
                                             Margin="0,0,14,0" FontSize="13" FontWeight="Bold"/>
                                <RadioButton x:Name="RbD" Content="D" GroupName="Raspuns"
                                             FontSize="13" FontWeight="Bold"/>
                            </WrapPanel>
                        </Border>
                        <TextBlock x:Name="ErrRaspuns" Style="{StaticResource ErrorMsg}"
                                   Text="Selectați răspunsul corect."/>
                    </StackPanel>

                    <!-- Dificultate ComboBox -->
                    <StackPanel Grid.Column="2">
                        <Label Content="_Dificultate" Style="{StaticResource FormLabel}"
                               Target="{Binding ElementName=CmbDificultate}"/>
                        <ComboBox x:Name="CmbDificultate" Style="{StaticResource InputCombo}" SelectedIndex="0">
                            <ComboBoxItem Content="🟢 Ușor"/>
                            <ComboBoxItem Content="🟡 Mediu"/>
                            <ComboBoxItem Content="🔴 Greu"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Tip cunoștințe (CheckBox) -->
                <StackPanel Margin="0,0,0,12">
                    <Label Content="Tip _Cunoștințe" Style="{StaticResource FormLabel}"/>
                    <Border BorderBrush="#CCCCDD" BorderThickness="1" CornerRadius="4" Padding="10,8">
                        <WrapPanel>
                            <CheckBox x:Name="ChkTeorie" Content="Teorie"
                                      Margin="0,0,18,4" FontSize="12"/>
                            <CheckBox x:Name="ChkPractica" Content="Practică"
                                      Margin="0,0,18,4" FontSize="12"/>
                            <CheckBox x:Name="ChkSintaxa" Content="Sintaxă"
                                      Margin="0,0,18,4" FontSize="12"/>
                            <CheckBox x:Name="ChkAlgoritmi" Content="Algoritmi"
                                      FontSize="12"/>
                        </WrapPanel>
                    </Border>
                </StackPanel>

                <!-- Mesaj succes -->
                <Border x:Name="PanelSucces" Background="#D4EDDA" CornerRadius="6"
                        Padding="14,10" Margin="0,4,0,0" Visibility="Collapsed">
                    <TextBlock Text="✔  Întrebarea a fost salvată cu succes!"
                               Foreground="#155724" FontWeight="Bold" FontSize="13"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ FOOTER BUTOANE ══ -->
        <Border Grid.Row="2" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="✖  Anulează"
                        Style="{StaticResource BtnSecondary}" Click="OnAnuleaza"/>
                <Button Grid.Column="2" Content="💾  Salvează Întrebarea"
                        Style="{StaticResource BtnPrimary}" Click="OnSalveaza"/>
            </Grid>
        </Border>
    </Grid>
</Window>
